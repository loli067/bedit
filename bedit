clear
current_dir=$(pwd) 
cd /snap/boot_editor_v13r3
echo "Welcome to bedit" 
     echo "1. Unpack image"
     echo "2. Unpack image assume the name is boot.img"
     echo "3. Pack image"
     echo "4. Exit" 
read option 
if [ "$option" = "4" ]; then 
echo "Bye bye" 
exit 0
fi 
if [ "$option" = "2" ]; then 
sudo cp -r -f "$current_dir/boot.img /snap/boot_editor_v13r3/boot.img"
cd /snap/boot_editor_v13r3 
sudo ./beditor unpack 
sudo cp -r "build" "$current_dir/unpacked_boot_image"
if [ $? -ne 0 ]; then
echo "Error Detected may not work try agian"
exit 1
fi
exit 0
fi
if [ "$option" = "1" ]; then
echo "Your boot image name include .img"
read "boot_image_name"
sudo cp -r -f "$current_dir/$boot_image_name /snap/boot_editor_v13r3/boot.img"
cd /snap/boot_editor_v13r3
sudo ./beditor unpack
sudo cp -r "build" "$current_dir/unpacked_boot_image"
if [ $? -ne 0 ]; then
echo "Error Detected may not work try agian"
exit 1
fi
exit 0
fi
if [ "$option" = "3" ]; then
sudo rm -rf "/snap/boot_editor_v13r3/build"
sudo cp -r -f "$current_dir/unpacked_boot_image" "/snap/boot_editor_v13r3/build"
sudo ./beditor pack
sudo mv "/snap/boot_editor_v13r3/boot.img.signed" "$current_dir/repacked image.img"
if [ $? -ne 0 ]; then
echo "Error Detected may not work try agian"
exit 1
fi
exit 0
fi
