current_dir=$(pwd)
cd /snap/bedit
help() {
echo "Usage: bedit unpack <filename>"
echo ""
echo ""
echo "Usage: bedit pack"
echo ""
echo ""
echo ""
exit 0
}
if [ -z "$1" ]; then
echo "Invalid command. Use 'bedit -h' to see available options."
exit 0
fi
if [ "$1" = "help" ]; then
help
fi
if [ "$1" = "h" ]; then
help
fi
if [ "$1" = "-h" ]; then
help
fi
if [ "$1" = "--h" ]; then
help
fi
if [ "$1" = "unpack" ]; then
if [ -z "$2" ]; then
echo "Usage: bedit unpack <bootimage.img>"
exit 0
fi
clear
sudo rm -rf "/snap/bedit/boot.img"
sudo cp -r -f "$current_dir/$2" "/snap/bedit/boot.img"
cd /snap/bedit
sudo ./beditor unpack
sudo cp -r "build" "$current_dir/unpacked_boot_image"
if [ $? -ne 0 ]; then
echo "Error Detected may not work try again"
exit 1
fi
exit 0
fi
if [ "$1" = "pack" ]; then
clear
sudo rm -rf "/snap/bedit/build"
sudo cp -r -f "$current_dir/unpacked_boot_image" "/snap/bedit/build"
sudo ./beditor pack
sudo mv "/snap/bedit/boot.img.signed" "$current_dir/repacked_image.img"
if [ $? -ne 0 ]; then
echo "Error Detected may not work try again"
exit 1
fi
exit 0
fi
echo "Invalid command. Use 'help' to see available options."
exit 0
